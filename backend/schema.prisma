// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== USER & AUTHENTICATION ==========

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student?
  teacher Teacher?
  admin   Admin?

  @@map("users")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

// ========== STUDENT PROFILE ==========

model Student {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age             Int?
  className       String?
  points          Int      @default(0)
  currentRankId   String?
  currentRank     Rank?    @relation(fields: [currentRankId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submissions     ActivitySubmission[]
  missionSubmissions MissionSubmission[]
  teamMembers     TeamMember[]
  badges          StudentBadge[]
  rewards         StudentReward[]
  challenges      Challenge[]
  challengedBy    Challenge[] @relation("ChallengedBy")
  history         ActivityHistory[]

  @@map("students")
}

// ========== TEACHER PROFILE ==========

model Teacher {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization  String?
  institution     String?
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activities      Activity[]
  missions        Mission[]
  feedbacks       Feedback[]

  @@map("teachers")
}

// ========== ADMIN PROFILE ==========

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ========== RANKS & PROGRESSION ==========

model Rank {
  id          String   @id @default(cuid())
  name        String   @unique
  level       Int      @unique
  minPoints   Int
  maxPoints   Int
  benefits    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    Student[]
  badges      StudentBadge[]

  @@map("ranks")
}

// ========== BADGES & ACHIEVEMENTS ==========

model StudentBadge {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rankId    String
  rank      Rank     @relation(fields: [rankId], references: [id])
  earnedAt  DateTime @default(now())

  @@unique([studentId, rankId])
  @@map("student_badges")
}

// ========== ACTIVITIES ==========

model Activity {
  id              String   @id @default(cuid())
  title           String
  description     String
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  status          ActivityStatus @default(ACTIVE)
  difficulty      DifficultyLevel @default(MEDIUM)
  points          Int
  dueDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objectives      Objective[]
  challenges      ActivityChallenge[]
  submissions     ActivitySubmission[]
  rewards         ActivityReward[]
  history         ActivityHistory[]

  @@map("activities")
}

enum ActivityStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

model Objective {
  id          String   @id @default(cuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  description String
  points      Int      @default(10)
  order       Int
  createdAt   DateTime @default(now())

  @@map("objectives")
}

model ActivityChallenge {
  id          String   @id @default(cuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  title       String
  description String
  points      Int
  order       Int
  createdAt   DateTime @default(now())

  @@map("activity_challenges")
}

// ========== ACTIVITY SUBMISSIONS & EVALUATION ==========

model ActivitySubmission {
  id          String   @id @default(cuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content     String
  status      SubmissionStatus @default(PENDING)
  score       Int?
  feedback    Feedback?
  submittedAt DateTime @default(now())
  evaluatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([activityId, studentId])
  @@map("activity_submissions")
}

enum SubmissionStatus {
  PENDING
  EVALUATED
  APPROVED
  REJECTED
  RESUBMITTED
}

model Feedback {
  id           String   @id @default(cuid())
  submissionId String   @unique
  submission   ActivitySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  comment      String
  rating       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("feedbacks")
}

// ========== MISSIONS ==========

model Mission {
  id          String   @id @default(cuid())
  title       String
  description String
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  difficulty  DifficultyLevel @default(MEDIUM)
  points      Int
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions MissionSubmission[]
  rewards     MissionReward[]

  @@map("missions")
}

model MissionSubmission {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content   String
  status    SubmissionStatus @default(PENDING)
  score     Int?
  submittedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([missionId, studentId])
  @@map("mission_submissions")
}

// ========== REWARDS ==========

model ActivityReward {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  name       String
  description String
  points     Int
  type       RewardType @default(POINTS)
  createdAt  DateTime @default(now())

  @@map("activity_rewards")
}

model MissionReward {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  name      String
  description String
  points    Int
  type      RewardType @default(POINTS)
  createdAt DateTime @default(now())

  @@map("mission_rewards")
}

model StudentReward {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name      String
  type      RewardType
  value     String
  redeemedAt DateTime?
  createdAt DateTime @default(now())

  @@map("student_rewards")
}

enum RewardType {
  POINTS
  VIRTUAL_ITEM
  DISCOUNT
  CERTIFICATE
  BADGE
}

// ========== TEAMS ==========

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     TeamMember[]
  challenges  TeamChallenge[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  @@unique([teamId, studentId])
  @@map("team_members")
}

enum TeamRole {
  LEADER
  MEMBER
}

// ========== CHALLENGES BETWEEN STUDENTS ==========

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  challengerId String
  challenger  Student  @relation(fields: [challengerId], references: [id], onDelete: Cascade)
  challengedId String
  challenged  Student  @relation("ChallengedBy", fields: [challengedId], references: [id], onDelete: Cascade)
  points      Int
  status      ChallengeStatus @default(PENDING)
  winnerId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("challenges")
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

// ========== TEAM CHALLENGES ==========

model TeamChallenge {
  id       String   @id @default(cuid())
  teamId1  String
  team1    Team     @relation(fields: [teamId1], references: [id], onDelete: Cascade)
  teamId2  String
  title    String
  points   Int
  status   ChallengeStatus @default(PENDING)
  winnerId String?
  createdAt DateTime @default(now())

  @@map("team_challenges")
}

// ========== NOTIFICATIONS ==========

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  readAt    DateTime?

  @@map("notifications")
}

enum NotificationType {
  ACTIVITY_CREATED
  MISSION_CREATED
  SUBMISSION_EVALUATED
  CHALLENGE_RECEIVED
  REWARD_EARNED
  RANK_UP
  TEAM_INVITED
  FEEDBACK_RECEIVED
  ACTIVITY_CLOSED
}

// ========== ACTIVITY HISTORY & ANALYTICS ==========

model ActivityHistory {
  id          String   @id @default(cuid())
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  attempts    Int      @default(0)
  score       Int?
  difficulty  DifficultyLevel
  createdAt   DateTime @default(now())

  @@map("activity_history")
}

// ========== PERFORMANCE REPORTS ==========

model PerformanceReport {
  id          String   @id @default(cuid())
  teacherId   String
  generatedAt DateTime @default(now())
  data        String   // JSON string with analytics
  createdAt   DateTime @default(now())

  @@map("performance_reports")
}