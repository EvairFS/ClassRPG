PORT=3001
NODE_ENV=development

# Configurações do Banco de Dados (PostgreSQL / Supabase)
# Use SUPABASE_POOLER_URL para o Session Pooler do Supabase quando disponível.
# Caso contrário, DATABASE_URL também funciona.
# Para Supabase/Render, defina DB_SSL=require ou PGSSLMODE=require.
SUPABASE_POOLER_URL=postgresql://postgres.<project_id>:senha@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://usuario:senha@seu_host_supabase.co:5432/nome_do_banco
SUPABASE_DB_URL=postgresql://usuario:senha@seu_host_supabase.co:5432/nome_do_banco
PGHOST=seu_host_supabase.co
PGPORT=5432
PGUSER=postgres
PGPASSWORD=sua_senha_aqui
PGDATABASE=postgres
PGSSLMODE=require
DB_SSL=require

# Autenticação e Segurança
JWT_SECRET=sua_chave_secreta_jwt_aqui
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Limitação de Taxa de Requisições (Rate Limit)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100